# Normalize text files
* text=auto eol=lf

# Unity YAML assets should stay as text
*.cs text
*.cginc text
*.compute text
*.cpp text
*.h text
*.hlsl text
*.json text
*.mat text
*.meta text
*.prefab text
*.shader text
*.shadergraph text
*.txt text
*.unity text
*.uss text
*.uxml text
*.yaml text
*.yml text

# Common Unity binary/source assets via Git LFS
